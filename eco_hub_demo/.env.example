# =============================
# Dữ liệu portable (chỉ bản .exe PyInstaller)
# =============================
# Mặc định: thư mục "data" cạnh EcoHub.exe (config, DB, video, logs nằm trong đó).
# Ghi đè nếu cần lưu sang ổ khác — nên dùng đường dẫn tuyệt đối, thư mục phải có quyền ghi.
# ECOHUB_DATA_DIR=D:\EcoHubData

# =============================
# Máy chủ web (tùy chọn — mặc định 127.0.0.1:5000)
# =============================
ECOHUB_HTTP_HOST=127.0.0.1
ECOHUB_HTTP_PORT=5000
# Bản exe (PyInstaller): mặc định tự mở trình duyệt — đặt 0 để tắt
ECOHUB_OPEN_BROWSER=1
# Flask debug: bản exe mặc định tắt; dev đặt 1 để bật
ECOHUB_FLASK_DEBUG=

# =============================
# Nguồn đơn hàng (TikTok API vs mã cục bộ Shopee/khác — chưa có API)
# =============================
# tiktok = gọi TikTok Shop API (mặc định)
# generic | shopee | lazada | other | manual = không gọi TikTok; chỉ dùng mã quét/nhập + lưu video
ECOHUB_ORDER_PLATFORM=tiktok
# Nhãn hiển thị cột "Nền tảng" khi chế độ generic (vd SHOPEE, LAZADA, KHAC)
ECOHUB_GENERIC_ORDER_PLATFORM=SHOPEE_OTHER

# =============================
# EcoHub - TikTok shared credentials
# =============================
ECOHUB_SECRET_KEY=0m9Vx2Qp7Lr4Nf8Ka1Zt6Hy3Ud5Ws9Bj2Ce7Mv4Xp8Qa6Rn1Tk5Yh3Pu0Ls2Gd9
ECOHUB_BOOTSTRAP_ADMIN_USERNAME=admin
ECOHUB_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
ECOHUB_REMEMBER_ME_DAYS=30
ECOHUB_ENABLE_EMAIL_RESET=0
ECOHUB_LOGIN_FAIL_THRESHOLD=5
ECOHUB_LOGIN_LOCK_MINUTES=15
ECOHUB_LOGIN_CAPTCHA_AFTER_FAILS=3
ECOHUB_APP_BASE_URL=http://localhost:5000
ECOHUB_RESET_PASSWORD_SALT=ecohub-reset-password
ECOHUB_SMTP_HOST=smtp.gmail.com
ECOHUB_SMTP_PORT=587
ECOHUB_SMTP_USE_TLS=1
ECOHUB_SMTP_USER=your-account@gmail.com
ECOHUB_SMTP_PASSWORD=your-app-password
ECOHUB_SMTP_FROM_EMAIL=your-account@gmail.com
ECOHUB_SMTP_FROM_NAME=EcoHub
ECOHUB_TIKTOK_BASE_URL=https://open-api.tiktokglobalshop.com
ECOHUB_TIKTOK_APP_KEY=6j1sjudpjo33u
ECOHUB_TIKTOK_APP_SECRET=ff0dbb2ad7b51a883a9c46c4fe9d227f0c188b70
# Optional fallback cho máy đã biết shop từ trước.
# Flow khuyến nghị: để trống/cmt, bấm "Kết nối TikTok" để app tự lưu shop_id/shop_cipher/token vào DB.
# ECOHUB_TIKTOK_SHOP_CIPHER=YOUR_SHOP_CIPHER
ECOHUB_TIKTOK_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
# Optional fallback; app có thể tự lấp sau callback/enrichment nếu TikTok trả về.
# ECOHUB_TIKTOK_SHOP_ID=
# ECOHUB_TIKTOK_MERCHANT_ID=
ECOHUB_TIKTOK_VERSION=202309
ECOHUB_TIKTOK_TIMEOUT_SEC=20
ECOHUB_TIKTOK_AUTH_HEADER=x-tts-access-token
ECOHUB_TIKTOK_AUTH_SCHEME=
ECOHUB_TIKTOK_INCLUDE_ACCESS_TOKEN_QUERY=true
ECOHUB_TIKTOK_DEFAULT_QUERY_PARAMS={}
ECOHUB_TIKTOK_EXTRA_HEADERS={"Content-Type":"application/json"}
ECOHUB_TIKTOK_SERVICE_ID=7604636951182493460
ECOHUB_TIKTOK_AUTH_BASE_URL=https://services.tiktokshop.com/open/authorize
ECOHUB_TIKTOK_REDIRECT_URI=http://localhost:5000/api/auth/tiktok/callback
ECOHUB_TIKTOK_TOKEN_EXCHANGE_URL=https://auth.tiktok-shops.com/api/v2/token/get
# Tên shop hiển thị trên trang TikTok (giao diện người bán), không bắt buộc
ECOHUB_TIKTOK_SHOP_DISPLAY_NAME=
# Link hướng dẫn (mặc định: cổng đối tác TikTok Shop)
ECOHUB_TIKTOK_HELP_URL=https://partner.tiktokshop.com/

# =============================
# Order-specific config (chỉ cho luồng quét đơn trên dashboard)
# =============================
ECOHUB_ORDER_API_METHOD=POST
ECOHUB_ORDER_API_ENDPOINT_PATH=/order/202309/orders/search
ECOHUB_ORDER_API_LOOKUP_FIELD=
ECOHUB_ORDER_API_QUERY_PARAMS={"version":"202309","page_size":"20"}
ECOHUB_ORDER_API_BODY_TEMPLATE={}

# =============================
# Auto update (portable .exe)
# =============================
# Client .env: trỏ tới file latest.json public trên GitHub/raw URL/S3/web server.
# Khi có bản mới, EcoHub sẽ tải zip về data\updates rồi tự áp dụng update.
ECOHUB_UPDATE_MANIFEST_URL=https://raw.githubusercontent.com/j4ngler/EcoHub/main/eco_hub_demo/release/latest.json

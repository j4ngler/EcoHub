# ===========================================
# ECOHUB ENVIRONMENT VARIABLES
# ===========================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecohub?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://ecohub"
BACKEND_PUBLIC_URL="http://ecohub"

# Frontend
VITE_API_URL="http://ecohub/api"
VITE_HOST="127.0.0.1"
VITE_PORT="5173"
VITE_PUBLIC_HOST="ecohub"
VITE_PUBLIC_PORT="80"
VITE_PROXY_TARGET="http://127.0.0.1:3000"

# Video runtime
VIDEO_STORAGE_LIMIT_GB=50
VIDEO_COMPRESSION_PYTHON="python"
VIDEO_TARGET_SIZE_MB=4
FFMPEG_PATH=""
FFPROBE_PATH=""

# S3 / S3-compatible object storage
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="hn-2"
AWS_S3_BUCKET="video"
AWS_S3_ENDPOINT="https://s3.hn-2.cloud.cmctelecom.vn"
AWS_S3_FORCE_PATH_STYLE=true

# Capture runtime compatibility
CAPTURE_SERVICE_URL="http://127.0.0.1:5000"
CAPTURE_CONFIG_FILE=""

# Shipping Carriers API Keys
GHN_API_TOKEN=""
GHN_SHOP_ID=""
GHTK_API_TOKEN=""
VTP_API_TOKEN=""
SPX_API_TOKEN=""

# Sales Channels
SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""
LAZADA_APP_KEY=""
LAZADA_APP_SECRET=""

# TikTok OAuth / API
TIKTOK_SERVICE_ID="7604636951182493460"
TIKTOK_APP_KEY=""
TIKTOK_APP_SECRET=""
TIKTOK_BASE_URL="https://open-api.tiktokglobalshop.com"
TIKTOK_TIMEOUT_SEC="20"
TIKTOK_AUTH_BASE_URL="https://services.tiktokshop.com/open/authorize"
TIKTOK_TOKEN_EXCHANGE_URL="https://auth.tiktok-shops.com/api/v2/token/get"
TIKTOK_REFRESH_URL="https://auth.tiktok-shops.com/api/v2/token/refresh"

# Legacy-compatible TikTok env names from eco_hub_demo
ECOHUB_TIKTOK_BASE_URL="https://open-api.tiktokglobalshop.com"
ECOHUB_TIKTOK_APP_KEY=""
ECOHUB_TIKTOK_APP_SECRET=""
ECOHUB_TIKTOK_ACCESS_TOKEN=""
ECOHUB_TIKTOK_REFRESH_TOKEN=""
ECOHUB_TIKTOK_SHOP_ID=""
ECOHUB_TIKTOK_MERCHANT_ID=""
ECOHUB_TIKTOK_SHOP_CIPHER=""
ECOHUB_TIKTOK_VERSION="202309"
ECOHUB_TIKTOK_TIMEOUT_SEC="20"
ECOHUB_TIKTOK_AUTH_HEADER="x-tts-access-token"
ECOHUB_TIKTOK_AUTH_SCHEME=""
ECOHUB_TIKTOK_INCLUDE_ACCESS_TOKEN_QUERY="true"
ECOHUB_TIKTOK_DEFAULT_QUERY_PARAMS={}
ECOHUB_TIKTOK_EXTRA_HEADERS={"Content-Type":"application/json"}
ECOHUB_TIKTOK_SERVICE_ID="7604636951182493460"
ECOHUB_TIKTOK_AUTH_BASE_URL="https://services.tiktokshop.com/open/authorize"
ECOHUB_TIKTOK_REDIRECT_URI="http://ecohub/api/channels/auth/tiktok/callback"

# Email Configuration for EcoHub-Demo
MAIL_MAILER="smtp"
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USERNAME="your-account@gmail.com"
MAIL_PASSWORD="your-app-password"
MAIL_ENCRYPTION="tls"
MAIL_FROM_ADDRESS="your-account@gmail.com"
MAIL_FROM_NAME="EcoHub"
MAIL_REPLY_ADDRESS="your-account@gmail.com"
MAIL_REPLY_NAME="EcoHub"

# Legacy SMTP / auth settings from eco_hub_demo
ECOHUB_SECRET_KEY=""
ECOHUB_BOOTSTRAP_ADMIN_USERNAME="admin"
ECOHUB_BOOTSTRAP_ADMIN_PASSWORD="CHANGE_ME_TO_STRONG_PASSWORD"
ECOHUB_REMEMBER_ME_DAYS=30
ECOHUB_ENABLE_EMAIL_RESET=0
ECOHUB_LOGIN_FAIL_THRESHOLD=5
ECOHUB_LOGIN_LOCK_MINUTES=15
ECOHUB_LOGIN_CAPTCHA_AFTER_FAILS=3
ECOHUB_APP_BASE_URL="http://ecohub"
ECOHUB_RESET_PASSWORD_SALT="ecohub-reset-password"
ECOHUB_SMTP_HOST="smtp.gmail.com"
ECOHUB_SMTP_PORT=587
ECOHUB_SMTP_USE_TLS=1
ECOHUB_SMTP_USER="your-account@gmail.com"
ECOHUB_SMTP_PASSWORD="your-app-password"
ECOHUB_SMTP_FROM_EMAIL="your-account@gmail.com"
ECOHUB_SMTP_FROM_NAME="EcoHub"

# Legacy order API settings from eco_hub_demo (reference only)
ECOHUB_ORDER_API_METHOD="POST"
ECOHUB_ORDER_API_ENDPOINT_PATH="/order/202309/orders/search"
ECOHUB_ORDER_API_LOOKUP_FIELD=""
ECOHUB_ORDER_API_QUERY_PARAMS={"version":"202309","page_size":"20"}
ECOHUB_ORDER_API_BODY_TEMPLATE={}

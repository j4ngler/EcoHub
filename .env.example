# ===========================================
# ECOHUB ENVIRONMENT VARIABLES
# ===========================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecohub?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:3000/api

# Video storage
# Tổng dung lượng (GB) dùng để tính % cảnh báo trên dashboard (mặc định: 50)
VIDEO_STORAGE_LIMIT_GB=50

# Cloud Storage (AWS S3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET="ecohub-videos"

# Or Google Cloud Storage
GCS_PROJECT_ID=""
GCS_BUCKET_NAME=""
GCS_KEY_FILE=""

# Shipping Carriers API Keys
GHN_API_TOKEN=""
GHN_SHOP_ID=""
GHTK_API_TOKEN=""
VTP_API_TOKEN=""
SPX_API_TOKEN=""

# Sales Channels
SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""
TIKTOK_APP_ID=""
TIKTOK_APP_SECRET=""
LAZADA_APP_KEY=""
LAZADA_APP_SECRET=""

# Email Configuration
MAIL_MAILER=smtp
MAIL_HOST=e2.vinahost.vn
MAIL_PORT=465
MAIL_USERNAME="dev@ecotel.com.vn"
MAIL_PASSWORD=EcotelEmail
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="dev@ecotel.com.vn"
MAIL_FROM_NAME="ecotel"
MAIL_REPLY_ADDRESS="dev@ecotel.com.vn"
MAIL_REPLY_NAME="ecotel"
